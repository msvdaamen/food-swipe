{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "food-swipe-backend",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-10",
  "observability": {
    "enabled": true
  },
  "route": {
    "pattern": "api.food-swipe.app",
    "custom_domain": true
  },
  "upload_source_maps": true,
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "API_URL": "http://localhost:8787",
    "WEB_URL": "http://localhost:5173",
    "ENVIRONMENT": "development",
    "STORAGE_PUBLIC_URL": "http://localhost:8787/r2-public"
  },
  "env": {
    "production": {
      "vars": {
        "API_URL": "https://api.food-swipe.app",
        "WEB_URL": "https://admin.food-swipe.app",
        "ENVIRONMENT": "production",
        "STORAGE_PUBLIC_URL": "https://static.food-swipe.app"
      },
      "kv_namespaces": [
        {
          "binding": "FOOD_SWIPE_CACHE",
          "id": "75eeffbe9f0c4c359c89b3cd16e2e092"
        }
      ],
      "hyperdrive": [
        {
          "binding": "HYPERDRIVE",
          "id": "957ba740f64444dca2a77e5862dfcb34"
        }
      ],
      "r2_buckets": [
        {
          "binding": "R2_PUBLIC",
          "bucket_name": "food-swipe-public"
        },
        {
          "binding": "R2_PRIVATE",
          "bucket_name": "food-swipe-private"
        }
      ]
    }
  },
  "kv_namespaces": [
    {
      "binding": "FOOD_SWIPE_CACHE",
      "id": "75eeffbe9f0c4c359c89b3cd16e2e092"
    }
  ],
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "957ba740f64444dca2a77e5862dfcb34",
      "localConnectionString": "postgres://postgres:postgres@localhost:5432/food-swipe"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2_PUBLIC",
      "bucket_name": "food-swipe-public"
    },
    {
      "binding": "R2_PRIVATE",
      "bucket_name": "food-swipe-private"
    }
  ]
}
